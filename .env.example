# ARK Vault - Environment Variables

# Telegram Bot Token (from @BotFather)
TELEGRAM_BOT_TOKEN=

# Notion Integration Token (from https://www.notion.so/my-integrations)
NOTION_TOKEN=

# Notion Parent Page ID - the page under which member journals are created
# Get this from the page URL: https://notion.so/Your-Page-{PAGE_ID}
NOTION_PARENT_PAGE_ID=

# Bot username (without @)
BOT_USERNAME=ark_vault_bot

# Log level: debug, info, warn, error
LOG_LEVEL=info

# --- Weekly Report Auto-Post ---
# Group chat ID to post weekly reports to (get via @userinfobot or bot API)
# Leave empty to disable auto-post
REPORT_CHAT_ID=

# Day of week to post report: sunday, monday, tuesday, etc.
REPORT_DAY=sunday

# Hour (0-23 UTC) to post the report
REPORT_HOUR=20

# --- Rate Limiting ---
# Max commands per user per minute (default: 10)
RATE_LIMIT_PER_MIN=10
