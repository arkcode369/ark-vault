# ARK Vault - Environment Variables

# Telegram Bot Token (from @BotFather)
TELEGRAM_BOT_TOKEN=

# Notion Integration Token (from https://www.notion.so/my-integrations)
NOTION_TOKEN=

# Notion Parent Page ID - the page under which member journals are created
# Get this from the page URL: https://notion.so/Your-Page-{PAGE_ID}
NOTION_PARENT_PAGE_ID=

# Bot username (without @)
BOT_USERNAME=ark_vault_bot

# Log level: debug, info, warn, error
LOG_LEVEL=info

# --- Weekly Report Auto-Post ---
# Group chat ID to post weekly reports to (get via @userinfobot or bot API)
# Leave empty to disable auto-post
REPORT_CHAT_ID=

# Topic/Thread ID for groups with Topics (Forum) enabled
# Get from the URL: web.telegram.org/a/#-100xxxx_69 → the number after underscore
# Leave empty or 0 to post to General / main chat
REPORT_THREAD_ID=

# Day of week to post report: sunday, monday, tuesday, etc.
REPORT_DAY=sunday

# Hour (0-23 UTC) to post the report
REPORT_HOUR=20

# --- BadgerDB (Gamification Storage) ---
# Path for BadgerDB data directory
BADGER_DB_PATH=/data/badger

# --- Rate Limiting ---
# Max commands per user per minute (default: 10)
RATE_LIMIT_PER_MIN=10

# --- Community Membership Gate ---
# Telegram group ID that users must be a member of to use the bot
# Leave empty to allow everyone (no gate)
COMMUNITY_GROUP_ID=

# Owner's Telegram user ID (for "contact owner" link in membership gate)
# Get via @userinfobot
OWNER_ID=
